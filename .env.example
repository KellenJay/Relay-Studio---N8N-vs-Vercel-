# Vercel KV (Redis) — get from Vercel dashboard after adding KV store
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Shared secret — must match the X-Relay-Secret header sent by n8n
RELAY_SECRET=your-secret-token-here

# n8n webhook base URL (used only for reference, not called from frontend)
N8N_WEBHOOK_BASE=https://your-n8n-instance.app.n8n.cloud/webhook
